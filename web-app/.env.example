# Web App Environment Variables (Vite — must use VITE_ prefix)

# Backend API base URL (with /api suffix for axios service)
VITE_API_BASE_URL=http://localhost:3001/api

# Backend server URL (without /api, for socket.io + standalone fetches)
VITE_API_URL=http://localhost:3001

# Blockchain RPC
VITE_RPC_URL=http://localhost:8545
VITE_CHAIN_ID=1337

# IPFS Gateway
VITE_IPFS_GATEWAY=https://ipfs.io/ipfs/
VITE_IPFS_API=https://ipfs.infura.io:5001

# Contract Addresses (update after deployment)
VITE_CIVTOKEN_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
