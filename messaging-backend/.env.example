# Server Configuration
PORT=3001
NODE_ENV=development

# Client Configuration
CLIENT_URL=http://localhost:3002

# JWT Secret (for future authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# File Upload Configuration
MAX_FILE_SIZE=52428800

# IPFS Configuration
# Mode options: 'local' (requires IPFS daemon), 'infura', 'pinata', 'disabled' (fallback)
IPFS_MODE=local
IPFS_HOST=localhost
IPFS_PORT=5001

# Infura IPFS (if using IPFS_MODE=infura)
# Get free account at https://infura.io
INFURA_PROJECT_ID=your_infura_project_id
INFURA_PROJECT_SECRET=your_infura_project_secret

# Pinata IPFS (if using IPFS_MODE=pinata)
# Get free account at https://pinata.cloud
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
