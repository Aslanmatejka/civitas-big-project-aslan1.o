# Smart Contracts Environment Variables

# Private key for deployment (NEVER commit your real key!)
PRIVATE_KEY=your_private_key_here

# RPC URLs
TESTNET_RPC_URL=https://testnet-rpc.civitas.network
MAINNET_RPC_URL=https://mainnet-rpc.civitas.network

# Etherscan API (for contract verification)
ETHERSCAN_API_KEY=your_etherscan_api_key

# Gas settings
GAS_PRICE=20
GAS_LIMIT=8000000

# Enable gas reporter
REPORT_GAS=false
